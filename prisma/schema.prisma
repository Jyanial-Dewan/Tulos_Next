generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model credentials {
  user_id  Int    @id
  password String
  users    users  @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_credentials_user")
}

model users {
  user_id     Int          @id @default(autoincrement())
  username    String       @unique @db.VarChar(20)
  user_type   String       @db.VarChar(10)
  email       String       @unique @db.VarChar(50)
  phone       Json
  first_name  String?      @db.VarChar(20)
  last_name   String?      @db.VarChar(20)
  created_at  DateTime?    @default(now()) @db.Timestamp(6)
  credentials credentials?
}

model categories {
  catagory_id   Int     @id @default(autoincrement())
  catagory_name String  @unique @db.VarChar(20)
  sizes         sizes[]
}

model collections {
  collection_id   Int    @id @default(autoincrement())
  collection_name String @unique @db.VarChar(20)
}

model colors {
  color_id   Int    @id @default(autoincrement())
  color_name String @unique @db.VarChar(20)
}

model tags {
  tag_id   Int    @id @default(autoincrement())
  tag_name String @unique @db.VarChar(20)
}

model availabilities {
  availability_id   Int    @id @default(autoincrement())
  availability_name String @unique @db.VarChar(20)
}

model brands {
  brand_id   Int    @id @default(autoincrement())
  brand_name String @unique @db.VarChar(20)
}

model genders {
  gender_id   Int    @id @default(autoincrement())
  gender_name String @unique @db.VarChar(20)
}

model sizes {
  size_id     Int        @id @default(autoincrement())
  catagory_id Int
  size_name   String     @db.VarChar(20)
  categories  categories @relation(fields: [catagory_id], references: [catagory_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_category")

  @@unique([catagory_id, size_name], map: "unique_category_size")
}
